rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isRoomMember(roomId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
    }
    function isRoomAdmin(roomId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.admins;
    }
    function isDMParticipant(dmId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isUser(uid);
    }

    // Rooms
    match /rooms/{roomId} {
      allow read: if isSignedIn() && (resource.data.isPublic == true || isRoomMember(roomId));
      allow create: if isSignedIn();
      allow update: if isRoomMember(roomId) || isRoomAdmin(roomId);
      allow delete: if isRoomAdmin(roomId);

      // Messages in rooms
      match /messages/{messageId} {
        allow read: if isRoomMember(roomId) || get(/databases/$(database)/documents/rooms/$(roomId)).data.isPublic == true;
        allow create: if isRoomMember(roomId) && request.resource.data.senderId == request.auth.uid;
        // Allow editing own messages (text/html only), or unsending own messages
        allow update: if isRoomMember(roomId) && (
          // Edit own message text
          (resource.data.senderId == request.auth.uid) ||
          // Mark seen (any member can update seenBy field)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy'])) ||
          // Add/remove reactions
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
        );
        allow delete: if isRoomAdmin(roomId);
      }
    }

    // DMs
    match /dms/{dmId} {
      allow read: if isDMParticipant(dmId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isDMParticipant(dmId);

      match /messages/{messageId} {
        allow read: if isDMParticipant(dmId);
        allow create: if isDMParticipant(dmId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isDMParticipant(dmId) && (
          resource.data.senderId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );
        allow delete: if false;
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }
  }
}
